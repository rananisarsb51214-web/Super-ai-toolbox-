- Return ONLY JavaScript
- No explanation
- Must be browser-executable
- Must complete the task safely
`;async function runOpenAI(prompt) {
  const res = await openai.chat.completions.create({
    model: "gpt-4.1-mini",
    messages: [
      { role: "system", content: "You generate safe DOM automation scripts." },
      { role: "user", content: prompt }
    ],
    temperature: 0.2
  });

  return res.choices[0].message.content;
}async function runClaude(prompt) {
  const res = await claude.messages.create({
    model: "claude-3-5-sonnet-20241022",
    max_tokens: 1500,
    messages: [
      {
        role: "user",
        content: prompt
      }async function hybridAI(prompt) {
  const [openaiRes, claudeRes] = await Promise.all([
    runOpenAI(prompt),
    runClaude(prompt)
  ]);

  // simple scoring merge strategy
  return openaiRes.length > claudeRes.length
    ? openaiRes
    : claudeRes;
}
    ]
  });

  return res.content[0].text;
}
}function chooseModel(context) {
  const complexity = context.dom.length;

  if (complexity > 80) return "claude";
  if (context.goal.includes("form") || context.goal.includes("login")) return "openai";

  return "openai";
}exports.generateDOMScript = async (req, res) => {
  const context = req.body;

  const prompt = buildPrompt(context);
  const model = chooseModel(context);

  let script;

  if (model === "openai") {
    script = await runOpenAI(prompt);
  } else {
    script = await runClaude(prompt);
  }

  res.json({
    script,
    modelUsed: model,
    confidence: 0.92
  });
