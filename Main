async function compileIntent(goal, domContext) {
  const prompt = `
Convert this into browser automation steps:

GOAL:
${goal}

DOM:
${JSON.stringify(domContext).slice(0, 8000)}

Return JSON:
[
  { "action": "navigate", "target": "" },
  { "action": "click", "selector": "" },
  { "action": "type", "selector": "", "value": "" }
]
`;

  const res = await fetch(AI_ENDPOINT, {
    method: "POST",
    body: JSON.stringify({ prompt })
  });

  return await res.json();
}


---

🧠 2. RL POLICY ENGINE (DECISION MAKER)

This is what makes it self-improving.

class PolicyEngine {
  constructor() {
    this.qTable = {}; // state-action value map
  }

  getKey(state, action) {
    return JSON.stringify({ state, action });
  }

  score(state, action) {
    return this.qTable[this.getKey(state, action)] || 0;
  }

  update(state, action, reward) {
    const key = this.getKey(state, action);
    this.qTable[key] = (this.qTable[key] || 0) + reward;
  }
}


---

⚡ 3. REINFORCEMENT LOOP (CORE LEARNING SYSTEM)

const policy = new PolicyEngine();

async function runAgent(plan, context) {
  for (const step of plan) {
    const state = context.url;

    try {
      execute(step);

      const reward = await evaluateStep(step);

      policy.update(state, step.action, reward);

    } catch (e) {
      policy.update(state, step.action, -1);
    }
  }
}


---

🧪 4. REWARD FUNCTION (LEARNING SIGNAL)

This is what makes the AI actually improve over time.

function evaluateStep(step) {
  if (step.action === "click") {
    const el = document.querySelector(step.selector);
    return el ? 1 : -1;
  }

  if (step.action === "type") {
    const el = document.querySelector(step.selector);
    return el?.value ? 1 : 0;
  }

  return 0;
}


---

