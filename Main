}export function scanDOM() {
  const elements = [...document.querySelectorAll("*")].slice(0, 200);

  return elements.map(el => ({
    tag: el.tagName,
    id: el.id,
    class: el.className,
    text: el.innerText?.slice(0, 80)
  }));
}export function scanDOM() {
  const elements = [...document.querySelectorAll("*")].slice(0, 200);

  return elements.map(el => ({
    tag: el.tagName,
    id: el.id,
    class: el.className,
    text: el.innerText?.slice(0, 80)
  }));
}export function buildContext(goal) {
  return {
    url: window.location.href,
    title: document.title,
    dom: scanDOM(),
    goal
  };export function runScript(code) {
  try {
    const fn = new Function(code);
    fn();
    return { ok: true };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}
